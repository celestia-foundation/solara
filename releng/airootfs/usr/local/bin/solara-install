#!/usr/bin/env bash
# Solara Installer - Simple text-based installer
# Usage: sudo solara-install

set -e

echo "🌅 Solara Installer"
echo "==================="
echo

# Check running as root
if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root (sudo solara-install)"
   exit 1
fi

# Get disk
echo "Available disks:"
lsblk -ndo NAME,SIZE,TYPE | grep -E "disk"
echo
read -p "Enter disk to install to (e.g., /dev/sda): " target_disk

if [[ ! -b "$target_disk" ]]; then
    echo "Error: $target_disk is not a valid block device"
    exit 1
fi

# Confirm
echo "WARNING: This will ERASE ALL DATA on $target_disk!"
read -p "Are you sure? Type 'yes' to continue: " confirm
if [[ "$confirm" != "yes" ]]; then
    echo "Aborted."
    exit 0
fi

# Partition
echo "Creating partitions..."
parted -s "$target_disk" mklabel gpt
parted -s "$target_disk" mkpart primary 1MiB 512MiB  # boot
parted -s "$target_disk" mkpart primary 512MiB 100%   # root

# Format
echo "Formatting..."
mkfs.fat -F32 "${target_disk}1"
mkfs.btrfs -f "${target_disk}2"

# Mount
mount "${target_disk}2" /mnt
mkdir -p /mnt/boot
mount "${target_disk}1" /mnt/boot

# Install base
echo "Installing Solara base system..."
pacstrap /mnt base base-devel linux linux-firmware sof-firmware

# Generate fstab
echo "Generating fstab..."
genfstab -U /mnt >> /mnt/etc/fstab

# Chroot setup
echo "Setting up system..."
arch-chroot /mnt /bin/bash -e << 'CHROOT'
# Set timezone
ln -sf /usr/share/zoneinfo/UTC /etc/localtime

# Locale
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen

# Hostname
echo "solara" > /etc/hostname

# Initramfs
mkinitcpio -P

# Boot loader
grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=Solara
grub-mkconfig -o /boot/grub/grub.cfg
CHROOT

echo
echo "✅ Installation complete!"
echo "Remove the ISO and reboot."
echo
echo "Default user: solara / solara"
echo "Root password: root"