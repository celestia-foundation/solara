#!/usr/bin/env bash
# Solara Installer - GUI installer (kdialog/zenity)
# Usage: sudo solara-install

set -e

# Detect dialog tool
if command -v kdialog &>/dev/null; then
    DIALOG="kdialog"
elif command -v zenity &>/dev/null; then
    DIALOG="zenity"
else
    echo "ERROR: Neither kdialog nor zenity found. Install one of them."
    exit 1
fi

msg()   { case "$DIALOG" in kdialog) kdialog --title "Solara Installer" --msgbox "$1" ;; zenity) zenity --title "Solara Installer" --info --text "$1" ;; esac; }
warn()  { case "$DIALOG" in kdialog) kdialog --title "Solara Installer" --warningyesno "$1" ;; zenity) zenity --title "Solara Installer" --question --text "$1" ;; esac; }
sorry() { case "$DIALOG" in kdialog) kdialog --title "Solara Installer" --sorry "$1" ;; zenity) zenity --title "Solara Installer" --error --text "$1" ;; esac; }
popup() { case "$DIALOG" in kdialog) kdialog --title "Solara Installer" --passivepopup "$1" "${2:-3}" ;; zenity) zenity --title "Solara Installer" --notification --text "$1" ;; esac; }

pick_disk() {
    local names=() descs=()
    while IFS= read -r line; do
        names+=($(echo "$line" | awk '{print $1}'))
        descs+=("$(echo "$line" | awk '{print $2}')")
    done < <(lsblk -ndo NAME,SIZE,TYPE | grep disk)

    case "$DIALOG" in
        kdialog)
            local args=()
            for i in "${!names[@]}"; do
                args+=("${names[$i]}" "/dev/${names[$i]}  (${descs[$i]})" "off")
            done
            kdialog --radiolist "Select disk to install Solara to" "${args[@]}"
            ;;
        zenity)
            local args=()
            for i in "${!names[@]}"; do
                args+=("${names[$i]}" "/dev/${names[$i]}  (${descs[$i]})")
            done
            zenity --list --title "Solara Installer" --text "Select disk to install Solara to" \
                --column "Disk" --column "Info" "${args[@]}" --print-column=1
            ;;
    esac
}

pick_flavor() {
    case "$DIALOG" in
        kdialog)
            kdialog --combobox "Select Solara flavor to install" \
                "KDE" "Cinnamon" "LXQt" "Pantheon" --default "KDE"
            ;;
        zenity)
            zenity --list --title "Solara Installer" --text "Select Solara flavor to install" \
                --column "Flavor" "KDE" "Cinnamon" "LXQt" "Pantheon"
            ;;
    esac
}

if [[ $EUID -ne 0 ]]; then
    sorry "This script must be run as root.\n\nsudo solara-install"
    exit 1
fi

# Detect boot mode
if [ -d /sys/firmware/efi ]; then
    BOOTMODE="UEFI"
else
    BOOTMODE="BIOS"
fi

# Pick disk
target=$(pick_disk)
if [[ -z "$target" ]]; then
    sorry "Installation cancelled."
    exit 0
fi
target_disk="/dev/$target"

# Pick flavor
flavor=$(pick_flavor)
if [[ -z "$flavor" ]]; then
    sorry "Installation cancelled."
    exit 0
fi

# Set flavor packages
case "$flavor" in
    KDE)
        DE_PKGS="plasma-meta plasma-login-manager kde-applications-meta"
        DM_SVC="plasma-login-manager"
        ;;
    Cinnamon)
        DE_PKGS="cinnamon cinnamon-screensaver cinnamon-session nemo nemo-fileroller \
                 eog xed celluloid xreader lightdm lightdm-gtk-greeter"
        DM_SVC="lightdm"
        ;;
    LXQt)
        DE_PKGS="lxqt lxqt-session pcmanfm-qt qterminal featherpad pavucontrol-qt \
                 papirus-icon-theme sddm"
        DM_SVC="sddm"
        ;;
    Pantheon)
        DE_PKGS="pantheon pantheon-session gala wingpanel switchboard \
                 elementary-icon-theme elementary-wallpapers lightdm lightdm-pantheon-greeter \
                 pantheon-terminal pantheon-files epiphany"
        DM_SVC="lightdm"
        ;;
esac

# Confirm
if ! warn "This will ERASE ALL DATA on $target_disk

Flavor: $flavor
Boot mode: $BOOTMODE

Proceed?"; then
    exit 0
fi

# Detect partition suffix
if echo "$target_disk" | grep -q "nvme\|mmcblk\|nbd"; then
    P="${target_disk}p"
else
    P="${target_disk}"
fi

# Partition
popup "Partitioning $target_disk..." 3

parted -s "$target_disk" mklabel gpt
if [ "$BOOTMODE" = "UEFI" ]; then
    parted -s "$target_disk" mkpart primary fat32 1MiB 512MiB
    parted -s "$target_disk" set 1 esp on
    parted -s "$target_disk" mkpart primary btrfs 512MiB 100%
else
    parted -s "$target_disk" mkpart primary 1MiB 2MiB
    parted -s "$target_disk" set 1 bios_grub on
    parted -s "$target_disk" mkpart primary btrfs 2MiB 100%
fi

# Format
popup "Formatting partitions..." 2

if [ "$BOOTMODE" = "UEFI" ]; then
    mkfs.fat -F32 "${P}1" >/dev/null 2>&1
    mkfs.btrfs -f "${P}2" >/dev/null 2>&1
    mount "${P}2" /mnt
    mkdir -p /mnt/boot
    mount "${P}1" /mnt/boot
else
    mkfs.btrfs -f "${P}2" >/dev/null 2>&1
    mount "${P}2" /mnt
fi

# Install
popup "Installing Solara (this may take a few minutes)..."

pacstrap /mnt base base-devel linux linux-firmware sof-firmware $DE_PKGS \
  sudo networkmanager

genfstab -U /mnt >> /mnt/etc/fstab

# Copy branding
cp /etc/os-release /mnt/etc/ 2>/dev/null || true
cp /etc/issue /mnt/etc/ 2>/dev/null || true
cp /etc/motd /mnt/etc/ 2>/dev/null || true

# Chroot config
popup "Configuring system..."

arch-chroot /mnt /bin/bash << CHROOT
ln -sf /usr/share/zoneinfo/US/Eastern /etc/localtime
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "solara" > /etc/hostname
useradd -m -G wheel,audio,video,storage -s /bin/bash solara
echo "solara:solara" | chpasswd
echo "root:root" | chpasswd
echo "%wheel ALL=(ALL:ALL) ALL" > /etc/sudoers.d/wheel
systemctl enable $DM_SVC
systemctl enable NetworkManager
mkinitcpio -P
CHROOT

# Bootloader
if [ "$BOOTMODE" = "UEFI" ]; then
    arch-chroot /mnt grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=Solara
else
    arch-chroot /mnt grub-install --target=i386-pc "$target_disk"
fi
arch-chroot /mnt grub-mkconfig -o /boot/grub/grub.cfg

msg "Installation complete!

Remove the ISO and reboot into Solara."
