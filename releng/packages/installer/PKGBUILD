# Maintainer: Celestia Foundation <https://github.com/celestiafoundation>
pkgname=solara-installer
pkgver=0.1.0
pkgrel=2
pkgdesc="Solara Linux GUI installer (Qt 6 + Rust)"
arch=('x86_64')
url="https://github.com/celestiafoundation/solara"
license=('GPL3')
depends=(
    'qt6-base'
    'qt6-declarative'
    'qt6-svg'
    'arch-install-scripts'
    'parted'
    'util-linux'
    'btrfs-progs'
    'e2fsprogs'
    'xfsprogs'
    'f2fs-tools'
    'dosfstools'
    'polkit'
    'networkmanager'
    'grub'
)
makedepends=(
    'rust'
    'cargo'
    'clang'
    'cmake'
    'pkgconf'
    'ninja'
    'qt6-base'
    'qt6-declarative'
    'qt6-tools'
)
options=('!strip' '!debug')

# Built straight out of the workspace tree (mounted at /solara in the build
# container). The cargo build happens BEFORE makepkg runs — see
# scripts/build-iso.sh — because makepkg's sandboxed LDFLAGS env drops the
# link instructions cxx-qt-lib emits for its static archive, and we don't want
# to fight that. PKGBUILD just packages the pre-built binary.
_srcroot="${startdir}/../../../installer"

build() {
    [[ -x "$_srcroot/target/release/solara-installer" ]] || {
        echo "ERROR: solara-installer binary not found at $_srcroot/target/release/" >&2
        echo "       Run cargo build --release -p installer-gui in $_srcroot first." >&2
        exit 1
    }
}

package() {
    install -Dm755 "$_srcroot/target/release/solara-installer" \
        "$pkgdir/usr/bin/solara-installer"

    install -Dm644 "$startdir/org.solara.installer.policy" \
        "$pkgdir/usr/share/polkit-1/actions/org.solara.installer.policy"

    install -Dm644 "$startdir/solara-installer.desktop" \
        "$pkgdir/usr/share/applications/solara-installer.desktop"
}
